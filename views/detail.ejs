<!DOCTYPE html>
<html>
<head>
  <title><%= property.title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>

  <header class="hero detail-hero">
    <h1><%= property.title %></h1>
    <p><%= property.location %></p>
  </header>

  <main class="container">
    <a class="back-link" href="/">← Back to listings</a>

    <section class="detail-card">
      <% if (property.image) { %>
        <img class="detail-image" src="<%= property.image %>" alt="<%= property.title %>">
      <% } %>
      <div class="detail-header">
        <div>
          <p class="property-type"><%= property.property_type %></p>
          <h2><%= property.title %></h2>
          <p class="location"><%= property.location %></p>
        </div>

        <p class="price big-price"><%= property.price %></p>
      </div>

      <div class="detail-grid">
        <div><strong>Rooms</strong><span><%= property.rooms || "N/A" %></span></div>
        <div><strong>Bathrooms</strong><span><%= property.bathrooms || "N/A" %></span></div>
        <div><strong>Size</strong><span><%= property.square_meters || "N/A" %> m²</span></div>
        <div><strong>Floor</strong><span><%= property.floor || "N/A" %></span></div>
      </div>

      <% if (property.URL) { %>
        <a class="external-button" href="<%= property.URL %>" target="_blank">
          Open original listing
        </a>
      <% } else { %>
        <p class="missing-url">Original listing URL not available.</p>
      <% } %>
    </section>
  </main>

</body>
</html>